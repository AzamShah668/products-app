# ─────────────────────────────────────────────────────────────
# Frontend configuration (Vite)
# Copy this file to "frontend/.env".
# NOTE: Vite inlines VITE_* variables at BUILD time, so changing
# this value requires a rebuild/redeploy.
# ─────────────────────────────────────────────────────────────

# Base URL of the backend API (no trailing slash).

# Local development:
VITE_API_URL=http://localhost:8000

# Production example (the live backend):
# VITE_API_URL=https://products-app-4odu.onrender.com

# ─────────────────────────────────────────────────────────────
# Backend configuration (FastAPI)
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env — it is gitignored.
# ─────────────────────────────────────────────────────────────

# Database connection string.
# Default: local SQLite file (note: ephemeral on free hosts like Render).
# For production use a managed Postgres URL, e.g.:
#   DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=sqlite:///./products.db

# Secret used to sign JWT access tokens.
# Generate a strong one:  openssl rand -hex 32
SECRET_KEY=change-me-run-openssl-rand-hex-32

# Access-token lifetime, in minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=120

# Optional — pin the Python version on some hosts (e.g. Render).
# PYTHON_VERSION=3.11.9
